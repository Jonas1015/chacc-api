# SQLite is the default db, you can use default / sqlite and both will resort to using sqlite db 
DATABASE_ENGINE=default

#For postgresql, uncomment and update the below values
# DATABASE_ENGINE=postgresql
# DATABASE_USER=chaccapi
# DATABASE_PASSWORD=welcome2chaccapi
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=chaccapidb


# ChaCC CLI
CHACC_DEPLOY_URL=http://localhost:8080

# Development Mode Configuration
DEVELOPMENT_MODE=False
ENABLE_PLUGIN_HOT_RELOAD=True
ENABLE_PLUGIN_DEPENDENCY_RESOLUTION=True
PLUGIN_AUTO_DISCOVERY=True

# Default Admin User (created by authentication module if no users exist)
AUTHENTICATION_DEFAULT_ADMIN_USERNAME=admin
AUTHENTICATION_DEFAULT_ADMIN_PASSWORD=admin

# JWT Secret (change in production!)
SECRET_KEY=your-secret-key-here