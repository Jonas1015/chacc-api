# ChaCC API - Production Environment Variables
# Copy this file to .env and fill in the values

SECRET_KEY=changeme-to-a-secure-random-32-char-key

DB_PASSWORD=changeme-to-a-secure-db-password
DATABASE_ENGINE=postgresql
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=chacc
DATABASE_USER=chacc

# (DO NOT CHANGE THESE)
DEVELOPMENT_MODE=False
ENABLE_PLUGIN_HOT_RELOAD=False
ENABLE_PLUGIN_DEPENDENCY_RESOLUTION=False
PLUGIN_AUTO_DISCOVERY=False
NO_RELOAD=True

#Only applies if you use Official ChaCC Authentication module 
AUTHENTICATION_DEFAULT_ADMIN_USERNAME=admin
AUTHENTICATION_ADMIN_PASSWORD=ChangeMe123!

LOG_LEVEL=INFO
